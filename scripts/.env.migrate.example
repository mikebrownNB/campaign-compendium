# Migration credentials — copy this file to scripts/.env.migrate and fill in your values.
# This file is gitignored; never commit .env.migrate.

# ── pf-dossier (SOURCE) ────────────────────────────────────────────────────────
# Your pf-dossier Supabase project URL and anon key (read-only access is enough)
PF_SUPABASE_URL=https://YOUR_PF_PROJECT.supabase.co
PF_SUPABASE_ANON_KEY=your-pf-dossier-anon-key

# ── campaign-compendium (DESTINATION) ──────────────────────────────────────────
# Your campaign-compendium Supabase project URL and SERVICE ROLE key (needed to bypass RLS on insert)
CC_SUPABASE_URL=https://YOUR_CC_PROJECT.supabase.co
CC_SERVICE_ROLE_KEY=your-campaign-compendium-service-role-key

# UUID of the super admin user (mike@mike-brown.ca) in campaign-compendium
# Find this in: Supabase dashboard → Authentication → Users → click user → copy UUID
CC_OWNER_USER_ID=your-super-admin-user-uuid
